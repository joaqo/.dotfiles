#!/bin/bash
# clean-cmux - reset cmux persisted state for a fresh start

rm -f "$HOME/Library/Application Support/cmux/session-com.cmuxterm.app.json"
rm -f "$HOME/.cmuxterm/claude-hook-sessions.json"
rm -f "$HOME/.cmuxterm/claude-hook-sessions.json.lock"
rm -f "$HOME/Library/Application Support/com.cmuxterm.app/browser_history.json"
rm -f "$HOME/Library/Caches/cmux/async.log"

echo "cmux state cleaned"
