#!/bin/bash
# Create a Mellow dev task via mellow CLI in a cmux workspace
# Usage: mellow-task "description" --branch <name> [--small] [--base branch] [--image path]...

set -e

# Parse args
description=""
branch=""
small=""
base=""
images=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --branch)
            shift
            branch_name="$1"
            branch="--branch $1"
            shift
            ;;
        --small)
            small="--small"
            shift
            ;;
        --base)
            shift
            base="--base $1"
            shift
            ;;
        --image)
            shift
            images+=("$1")
            shift
            ;;
        *)
            if [ -z "$description" ]; then
                description="$1"
            fi
            shift
            ;;
    esac
done

if [ -z "$description" ]; then
    echo "Usage: mellow-task \"description\" --branch <name> [--small] [--base branch] [--image path]..." >&2
    exit 1
fi

# Write prompt to temp file, include image paths if any
prompt_file="/tmp/mellow-task-prompt.txt"
printf '%s' "$description" > "$prompt_file"
if [ ${#images[@]} -gt 0 ]; then
    printf '\n\n---\nTask images (use the Read tool to view each one):\n' >> "$prompt_file"
    for img in "${images[@]}"; do
        printf -- '- %s\n' "$img" >> "$prompt_file"
    done
fi

# Create cmux workspace and run task inside it
export CMUX_SOCKET_PATH="${CMUX_SOCKET_PATH:-$(cat "$HOME/Library/Application Support/cmux/last-socket-path" 2>/dev/null)}"
CMUX_BIN="/Applications/cmux.app/Contents/Resources/bin/cmux"
MELLOW_BIN="$HOME/mellow/cli/src/index.ts"

# Ensure cmux is running — launch it if not
if ! "$CMUX_BIN" ping >/dev/null 2>&1; then
    open -a cmux
    for i in $(seq 1 15); do
        sleep 1
        if "$CMUX_BIN" ping >/dev/null 2>&1; then break; fi
    done
    # Re-read socket path after fresh launch
    export CMUX_SOCKET_PATH="$(cat "$HOME/Library/Application Support/cmux/last-socket-path" 2>/dev/null)"
    if ! "$CMUX_BIN" ping >/dev/null 2>&1; then
        echo "Error: cmux failed to start after 15s" >&2
        exit 1
    fi
fi

# Create worktree (or use ~/mellow for --small), then open workspace with correct cwd
task_path=$(cd ~/mellow && bun "$MELLOW_BIN" task create $small $branch $base -f "$prompt_file")
if [ -n "$small" ] && [ -n "$branch_name" ]; then
    session_name="MAIN:$branch_name"
else
    session_name=$(basename "$task_path")
fi
ws_output=$("$CMUX_BIN" new-workspace --cwd "$task_path" --command "claude --name \"$session_name\" \"\$(cat .task-prompt)\"")
ws_ref=$(echo "$ws_output" | grep -o 'workspace:[0-9]*')

# Name the workspace after the branch/worktree
if [ -n "$ws_ref" ]; then
    "$CMUX_BIN" rename-workspace --workspace "$ws_ref" "$session_name"
fi

# Add a lazygit tab in the new workspace, then focus back to claude tab
ws_flag=()
if [ -n "$ws_ref" ]; then ws_flag=(--workspace "$ws_ref"); fi
# Add lazygit tab
lg_output=$("$CMUX_BIN" new-surface "${ws_flag[@]}")
lg_ref=$(echo "$lg_output" | grep -o 'surface:[0-9]*')
if [ -n "$lg_ref" ]; then
    "$CMUX_BIN" send --surface "$lg_ref" "${ws_flag[@]}" "lazygit\n"
    "$CMUX_BIN" tab-action --action rename --surface "$lg_ref" "${ws_flag[@]}" --title "lazygit"
fi

# Add nvim tab
nvim_output=$("$CMUX_BIN" new-surface "${ws_flag[@]}")
nvim_ref=$(echo "$nvim_output" | grep -o 'surface:[0-9]*')
if [ -n "$nvim_ref" ]; then
    "$CMUX_BIN" send --surface "$nvim_ref" "${ws_flag[@]}" "nvim\n"
    "$CMUX_BIN" tab-action --action rename --surface "$nvim_ref" "${ws_flag[@]}" --title "nvim"
fi

# Focus claude tab (first surface)
claude_ref=$("$CMUX_BIN" list-pane-surfaces "${ws_flag[@]}" | grep -o 'surface:[0-9]*' | head -1)
if [ -n "$claude_ref" ]; then
    "$CMUX_BIN" move-surface --surface "$claude_ref" "${ws_flag[@]}" --focus true --index 0
fi
echo "Task started: $description"
